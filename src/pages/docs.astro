---
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';

const res = await fetch(
    'https://raw.githubusercontent.com/gummyniki/techlang/main/docs/LANGUAGE.md'
);

if (!res.ok) {
    throw new Error('Failed to fetch LANGUAGE.md: ' + res.status);
}

const rawMarkdown = await res.text();

function slugify(text) {
    return text.toLowerCase().trim().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
}

function escapeHtml(str) {
    return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
}

const KEYWORDS = new Set([
    'function', 'returns', 'return', 'if', 'else', 'while', 'for',
    'struct', 'enum', 'true', 'false', 'const', 'fixed', 'as',
    'extern', 'break', 'continue', 'kernel',
]);

const TYPES = new Set([
    'int', 'float', 'double', 'char', 'string', 'bool', 'none', 'any',
    'ArrayOf', 'PointerOf',
]);

// Lightweight Techlang highlighter (no grammar exists for it in shiki/highlight.js).
function highlightTechlang(code) {
    const tokenRe = /(\/\/[^\n]*)|("(?:[^"\\]|\\.)*")|('(?:[^'\\]|\\.)*')|(\b\d+\.?\d*\b)|(\b[A-Za-z_]\w*\b)/g;
    let out = '';
    let last = 0;
    let match;

    while ((match = tokenRe.exec(code))) {
        out += escapeHtml(code.slice(last, match.index));
        const [, comment, dstring, sstring, number, ident] = match;

        if (comment) {
            out += `<span class="c">${escapeHtml(comment)}</span>`;
        } else if (dstring) {
            out += `<span class="s">${escapeHtml(dstring)}</span>`;
        } else if (sstring) {
            out += `<span class="s">${escapeHtml(sstring)}</span>`;
        } else if (number) {
            out += `<span class="n">${escapeHtml(number)}</span>`;
        } else if (ident) {
            if (KEYWORDS.has(ident)) {
                out += `<span class="k">${ident}</span>`;
            } else if (TYPES.has(ident)) {
                out += `<span class="t">${ident}</span>`;
            } else if (code.charAt(tokenRe.lastIndex) === '(') {
                out += `<span class="f">${ident}</span>`;
            } else {
                out += ident;
            }
        }

        last = tokenRe.lastIndex;
    }

    out += escapeHtml(code.slice(last));
    return out;
}

const chapters = [];
const renderer = new marked.Renderer();

// Must be a regular function (not an arrow) — marked calls it with `this` bound
// to the renderer instance so `this.parser` is available for inline rendering.
renderer.heading = function (token) {
    const { depth, text, tokens } = token;
    const id = slugify(text);
    if (depth === 2 && text !== 'Table of Contents') {
        chapters.push({ id, text });
    }
    const inner = this.parser.parseInline(tokens);
    return `<h${depth} id="${id}">${inner}</h${depth}>\n`;
};

renderer.code = function (token) {
    const { text, lang } = token;
    const highlighted = lang === 'techlang' ? highlightTechlang(text) : escapeHtml(text);
    return `<pre class="cb"><code class="cb-code">${highlighted}</code></pre>\n`;
};

marked.use({ renderer });

// Registering the renderer above must happen before parsing, otherwise headings
// render without ids and the in-page "Table of Contents" links go nowhere.
const htmlContent = marked.parse(rawMarkdown);
---

<Layout
    title="Language Reference — Techlang"
    description="Complete reference for the Techlang programming language."
>
    <header class="site-header">
        <div class="header-inner">
            <a href={import.meta.env.BASE_URL} class="logo">Techlang</a>
            <nav class="header-nav">
                <a href={`${import.meta.env.BASE_URL}docs`} class="nav-link active">Docs</a>
                <a href="https://gummyniki.github.io/portfolio/blog" target="_blank" class="nav-link">Blog</a>
                <a href="https://github.com/gummyniki/techlang" target="_blank" class="nav-link">GitHub ↗</a>
            </nav>
        </div>
    </header>

    <div class="docs-layout">
        <aside class="sidebar">
            <div class="sidebar-title">Language Reference</div>
            <ul class="toc">
                {chapters.map(c => (
                    <li>
                        <a href={`#${c.id}`} class="toc-link" data-section={c.id}>{c.text}</a>
                    </li>
                ))}
            </ul>
            <div class="sidebar-footer">
                <a href="https://github.com/gummyniki/techlang" target="_blank" class="sidebar-ext-link">GitHub ↗</a>
                <a href="https://open-vsx.org/extension/gummyniki/techlang" target="_blank" class="sidebar-ext-link">VS Code ↗</a>
            </div>
        </aside>

        <main class="content">
            <div class="markdown-body" set:html={htmlContent} />
        </main>
    </div>
</Layout>

<script>
    // Highlight the sidebar entry matching the chapter currently in view.
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    const headings = document.querySelectorAll<HTMLElement>('.markdown-body h2[id]');

    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    links.forEach(l => l.classList.remove('toc-active'));
                    const active = document.querySelector(`.toc-link[data-section="${entry.target.id}"]`);
                    if (active) active.classList.add('toc-active');
                }
            });
        },
        { rootMargin: '-20% 0px -70% 0px' }
    );

    headings.forEach(h => observer.observe(h));
</script>

<style>
    /* ---- Header ---- */
    .site-header {
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        background: rgba(13, 13, 13, 0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        z-index: 50;
    }

    .header-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 1.1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--accent);
        font-family: 'JetBrains Mono', monospace;
        text-decoration: none;
    }
    .logo:hover { text-decoration: none; opacity: 0.85; }

    .header-nav {
        display: flex;
        gap: 2rem;
    }

    .nav-link {
        color: var(--text-muted);
        font-size: 0.9rem;
        transition: color 0.2s;
        text-decoration: none;
    }
    .nav-link:hover { color: var(--text); text-decoration: none; }
    .nav-link.active { color: var(--accent); }

    /* ---- Layout ---- */
    .docs-layout {
        display: flex;
        max-width: 1400px;
        margin: 0 auto;
        min-height: calc(100vh - 57px);
    }

    /* ---- Sidebar ---- */
    .sidebar {
        width: 250px;
        flex-shrink: 0;
        position: sticky;
        top: 57px;
        height: calc(100vh - 57px);
        overflow-y: auto;
        border-right: 1px solid var(--border);
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
    }

    .sidebar-title {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        margin-bottom: 1rem;
    }

    .toc {
        list-style: none;
        flex: 1;
    }

    .toc li { margin-bottom: 0.1rem; }

    .toc-link {
        display: block;
        padding: 0.35rem 0.75rem;
        border-radius: 6px;
        color: var(--text-muted);
        font-size: 0.875rem;
        transition: color 0.15s, background 0.15s;
        text-decoration: none;
    }
    .toc-link:hover {
        color: var(--text);
        background: rgba(255, 255, 255, 0.04);
        text-decoration: none;
    }
    .toc-link.toc-active {
        color: var(--accent);
        background: var(--accent-glow);
    }

    .sidebar-footer {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .sidebar-ext-link {
        color: var(--text-muted);
        font-size: 0.8rem;
        text-decoration: none;
        transition: color 0.2s;
    }
    .sidebar-ext-link:hover { color: var(--text); text-decoration: none; }

    /* ---- Content ---- */
    .content {
        flex: 1;
        padding: 3rem 4rem;
        max-width: 800px;
        min-width: 0;
    }

    /* ---- Markdown body ---- */
    .markdown-body :global(h1) {
        font-size: 2.25rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .markdown-body :global(h1 + p) {
        color: var(--text-muted);
        font-size: 1rem;
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }

    .markdown-body :global(h2) {
        font-size: 1.6rem;
        font-weight: 700;
        margin: 2.5rem 0 1rem;
        padding-bottom: 0.6rem;
        border-bottom: 1px solid var(--border);
        letter-spacing: -0.015em;
        scroll-margin-top: 80px;
    }

    .markdown-body :global(h3) {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin: 1.5rem 0 0.6rem;
        scroll-margin-top: 80px;
    }

    .markdown-body :global(p) {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.7;
        margin-bottom: 0.75rem;
    }

    .markdown-body :global(code) {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.1em 0.45em;
        font-size: 0.82em;
        font-family: 'JetBrains Mono', monospace;
        color: var(--text);
    }

    .markdown-body :global(pre.cb) {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.1rem 1.4rem;
        overflow-x: auto;
        margin: 0.75rem 0 1rem;
        transition: border-color 0.2s;
    }
    .markdown-body :global(pre.cb:hover) { border-color: #3a3a3a; }

    .markdown-body :global(pre.cb code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.83rem;
        line-height: 1.75;
        color: var(--text);
    }

    /* Syntax highlight spans */
    .markdown-body :global(.k) { color: #c792ea; }
    .markdown-body :global(.t) { color: #82aaff; }
    .markdown-body :global(.f) { color: #82e2ff; }
    .markdown-body :global(.c) { color: #546e7a; }
    .markdown-body :global(.s) { color: #c3e88d; }
    .markdown-body :global(.n) { color: #f78c6c; }

    .markdown-body :global(table) {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
        margin: 0.75rem 0 1rem;
    }

    .markdown-body :global(.table-wrap) {
        overflow-x: auto;
        margin: 0.75rem 0 1rem;
        border-radius: 8px;
        border: 1px solid var(--border);
    }

    .markdown-body :global(th) {
        padding: 0.65rem 1rem;
        text-align: left;
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
    }

    .markdown-body :global(td) {
        padding: 0.65rem 1rem;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
        color: var(--text);
    }

    .markdown-body :global(tbody tr:last-child td) { border-bottom: none; }
    .markdown-body :global(tbody tr:hover) { background: rgba(255, 255, 255, 0.02); }

    .markdown-body :global(ul) {
        color: var(--text-muted);
        margin: 0.75rem 0;
        padding-left: 1.5rem;
    }

    .markdown-body :global(li) {
        font-size: 0.95rem;
        line-height: 1.7;
        margin-bottom: 0.3rem;
    }

    .markdown-body :global(hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2.5rem 0;
    }

    .markdown-body :global(a) {
        color: var(--accent);
    }

    /* ---- Mobile ---- */
    @media (max-width: 768px) {
        .sidebar { display: none; }
        .content { padding: 2rem 1.5rem; }
    }
</style>
