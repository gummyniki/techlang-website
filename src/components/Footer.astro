---
---

<footer>
    <div class="container">
        <div class="footer-left">
            <div class="logo">Techlang</div>
            <p>A compiled language with seamless GPU compute.</p>
            <p class="license">MIT License — open source forever</p>
        </div>
        <div class="footer-links">
            <div class="link-group">
                <h4>Language</h4>
                <a href="https://github.com/gummyniki/techlang" target="_blank">GitHub</a>
                <a href="https://github.com/gummyniki/techlang/releases" target="_blank">Releases</a>
                <a href="https://github.com/gummyniki/techlang/blob/main/LANGUAGE.md" target="_blank">Docs</a>
            </div>
            <div class="link-group">
                <h4>Editor Support</h4>
                <a href="https://open-vsx.org/extension/gummyniki/techlang" target="_blank">VS Code</a>
                <a href="https://github.com/gummyniki/techlang-nvim" target="_blank">Neovim</a>
            </div>
            <div class="link-group">
                <h4>Author</h4>
                <a href="https://gummyniki.github.io/portfolio" target="_blank">Portfolio</a>
                <a href="https://gummyniki.github.io/portfolio/blog" target="_blank">Blog</a>
                <a href="https://github.com/gummyniki" target="_blank">GitHub</a>
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <p>Built with ❤️ and way too much C++</p>
    </div>
</footer>

<style>
    footer {
        border-top: 1px solid var(--border);
        padding: 3rem 2rem 1.5rem;
        margin-top: 2rem;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        gap: 3rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
    }

    .logo {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--accent);
        font-family: 'JetBrains Mono', monospace;
        margin-bottom: 0.75rem;
    }

    .footer-left p {
        color: var(--text-muted);
        font-size: 0.9rem;
        max-width: 250px;
        margin-bottom: 0.25rem;
    }

    .license {
        font-size: 0.8rem !important;
        margin-top: 0.5rem !important;
    }

    .footer-links {
        display: flex;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .link-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    h4 {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.25rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    a {
        color: var(--text-muted);
        font-size: 0.9rem;
        transition: color 0.2s;
    }

    a:hover {
        color: var(--text);
        text-decoration: none;
    }

    .footer-bottom {
        max-width: 1200px;
        margin: 0 auto;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        text-align: center;
        color: var(--text-muted);
        font-size: 0.85rem;
    }
</style>
